# T-MANAGE iPhone CTI Bridge 設定
# このファイルを .env にコピーしてから値を埋めてください

# ─── 必須 ─────────────────────────────────────
SUPABASE_URL=https://cbewozzdyjqmhzkxsjqo.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── 任意 ─────────────────────────────────────
# 店舗ID (マルチテナント用、アンジュスパは 1)
STORE_ID=1

# デバイスID (複数PC運用時の識別用、未指定ならPC名が入る)
# DEVICE_ID=front-desk-pc

# 通知ポーリング間隔 (秒)
POLL_INTERVAL_SEC=2.0

# 同一番号の重複送信防止ウィンドウ (秒)
DEDUP_WINDOW_SEC=30

# ログレベル (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO
